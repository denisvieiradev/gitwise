{
  "name": "gitwise-workspace",
  "version": "1.6.4",
  "description": "gitwise monorepo root (private). The publishable packages live under packages/*.",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:legacy && npm run build:workspaces",
    "build:legacy": "tsup",
    "build:workspaces": "npm run --workspaces --if-present build",
    "dev": "tsup --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --passWithNoTests",
    "lint": "tsc --noEmit && npm run --workspaces --if-present lint",
    "typecheck": "tsc --noEmit && npm run --workspaces --if-present typecheck"
  },
  "keywords": [
    "cli",
    "gitwise",
    "git",
    "ai",
    "claude",
    "code-review",
    "commit",
    "pull-request",
    "release"
  ],
  "author": "Denis Vieira <denisvieira05@gmail.com> (https://github.com/denisvieiradev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/denisvieiradev/devflow-cli.git"
  },
  "bugs": {
    "url": "https://github.com/denisvieiradev/devflow-cli/issues"
  },
  "homepage": "https://github.com/denisvieiradev/devflow-cli#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@clack/prompts": "^0.9.1",
    "@eslint/js": "^9.39.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.14",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "ora": "^8.2.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.0"
  }
}
