{
  "name": "@denisvieiradev/gitwise",
  "version": "1.6.4",
  "description": "AI-powered git toolbelt: intelligent commit, code review, PR drafting, and versioned releases.",
  "type": "module",
  "bin": {
    "gw": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest --passWithNoTests",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@denisvieiradev/gitwise-core": "*",
    "@clack/prompts": "^0.9.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  },
  "keywords": ["gitwise", "git", "ai", "commit", "review", "pull-request", "release"],
  "author": "Denis Vieira <denisvieira05@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
